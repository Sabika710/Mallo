generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id                       String   @id @default(cuid())
  clerkOrgId               String   @unique
  stripeAccountId          String?  @unique
  stripeOnboardingComplete Boolean  @default(false)
  name                     String
  returnPolicy             Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  products Product[]
  orders   Order[]
}

model Product {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String   @default("")
  price       Int // cents
  imageUrl    String?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand      Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Order {
  id             String      @id @default(cuid())
  brandId        String
  customerId     String
  customerEmail  String?
  status         OrderStatus @default(PENDING)
  // stripeIntentId is UNIQUE — used as idempotency key to prevent webhook duplication
  stripeIntentId String      @unique
  totalAmount    Int // cents
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  brand Brand       @relation(fields: [brandId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int // cents at time of purchase

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// Tracks processed Stripe event IDs to prevent duplicate processing
model ProcessedEvent {
  id          String   @id // Stripe event ID
  processedAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  DISPATCHED
  DELIVERED
  CANCELED
}
